{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*", "./*"]
    },
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["esnext", "dom"],
    "target": "esnext",
    "checkJs": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": []
  },
  "include": [
    "src/**/*",
    "lib/**/*",
    "firebase-export/**/*",
    "components/**/*",
    "layout/**/*",
    "dashboard/**/*",
    "profile/**/*",
    "venue/**/*"
  ],
  "exclude": ["node_modules", "dist", "src/vite-plugins"]
} 